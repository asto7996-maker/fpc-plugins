# =====================================================================
# Telegram Content & Marketing Bot — Configuration
# Copy this file to .env and fill in your values.
# =====================================================================

# ------------------------------------------------------------
# Required: Telegram credentials
# ------------------------------------------------------------

# Bot token from @BotFather
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Telegram user API credentials (from https://my.telegram.org)
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Comma-separated list of Telegram user IDs allowed to use the admin bot
ADMIN_IDS=123456789,987654321

# ------------------------------------------------------------
# Content Machine
# ------------------------------------------------------------

# Target channel where reposts will be published (@username or channel ID)
TARGET_CHANNEL=@my_target_channel

# Comma-separated list of donor channel usernames to monitor
DONOR_CHANNELS=@donor1,@donor2,@donor3

# Advertising text to append at the end of every repost
AD_TEXT=Больше контента в нашем канале!

# Inline button label and URL appended to each repost
AD_BUTTON_TEXT=Подписаться
AD_BUTTON_URL=https://t.me/my_private_channel

# How often to check donor channels for new posts (seconds, default 300 = 5 min)
CM_CHECK_INTERVAL=300

# Minimum delay between consecutive reposts (seconds, default 1800 = 30 min)
CM_REPOST_MIN_DELAY=1800

# Maximum number of reposts per day across all donors
CM_MAX_POSTS_PER_DAY=48

# Strip media metadata before reposting (true/false)
CM_STRIP_METADATA=true

# Add invisible Unicode chars to captions to avoid duplicate detection
CM_OBFUSCATE_CAPTION=true

# Skip posts older than this many hours
CM_MAX_POST_AGE_HOURS=48

# Comma-separated keywords — skip posts containing these words
CM_SKIP_KEYWORDS=

# ------------------------------------------------------------
# Parser
# ------------------------------------------------------------

# Source groups to parse (comma-separated usernames or links)
PARSER_GROUPS=@competitor_group1,@competitor_group2

# Only collect users seen online within this window (hours)
PARSER_ACTIVITY_HOURS=24

# Max users to collect per single parse run
PARSER_MAX_PER_RUN=500

# Delay between participant-batch requests (seconds)
PARSER_BATCH_DELAY=2.0

# How often to run the parser automatically (seconds, 7200 = 2 hours)
PARSER_RUN_INTERVAL=7200

# Skip bots from results
PARSER_SKIP_BOTS=true

# ------------------------------------------------------------
# Inviter / DM Spammer
# ------------------------------------------------------------

# Channel/group to invite users to (@username)
INVITE_TARGET=@my_open_channel

# DM message template (placeholders: {first_name}, {link})
DM_MESSAGE=Привет, {first_name}! У нас есть закрытый канал с эксклюзивным контентом. Заходи: {link}

# Inline button in DM
DM_BUTTON_TEXT=Перейти в канал
DM_BUTTON_URL=https://t.me/my_private_channel

# Base delay between invite/DM actions in seconds (±30% jitter applied)
INVITER_DELAY=45.0

# Maximum invites per account per day
INVITER_MAX_PER_ACCOUNT=30

# Maximum DMs per account per day
INVITER_MAX_DM_PER_ACCOUNT=15

# Pause duration (seconds) after a PeerFlood or similar error
INVITER_ERROR_PAUSE=300

# Disable account after this many consecutive errors
INVITER_MAX_ERRORS=5

# ------------------------------------------------------------
# Accounts & Proxies
# ------------------------------------------------------------

# Directory containing .session files for worker accounts
SESSIONS_DIR=sessions

# Proxy list file (one per line: socks5://user:pass@host:port)
PROXY_FILE=proxies.txt

# Rotate to the next account every N actions
ACCOUNTS_ROTATE_EVERY=10

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

DB_PATH=data/bot.db

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ------------------------------------------------------------
# Temp media directory (downloaded files before repost)
# ------------------------------------------------------------
MEDIA_DIR=media
