# Telegram bot token from @BotFather.
BOT_TOKEN=123456789:replace_me

# Numeric Telegram user IDs of administrators, comma-separated.
# You can get your id from @userinfobot or similar.
ADMIN_IDS=123456789

# Target channel id or @username. The bot must be an admin in this channel.
TARGET_CHANNEL_ID=@your_public_channel

# SQLite database path.
DATABASE_PATH=data/content_machine.sqlite3

# If true, new RSS/channel/manual posts go to moderation first.
REVIEW_REQUIRED=true

# Add "Источник: <link>" to published posts when the source has a public link.
APPEND_SOURCE_LINK=true

# Optional signature/ad block appended to every published post.
AD_SIGNATURE=Подписывайтесь: https://t.me/your_public_channel

# Optional RSS/Atom feeds added on first start. Separate by comma, semicolon, or newline.
RSS_FEEDS=https://example.com/feed.xml

# Optional Telegram source channel ids that are explicitly allowed.
# Bot API receives channel_post updates only when the bot is present/admin there.
ALLOWED_SOURCE_CHANNEL_IDS=-1001234567890

# Runtime tuning.
FEED_INTERVAL_SEC=180
SCHEDULER_INTERVAL_SEC=10
POLL_TIMEOUT_SEC=25
BROADCAST_DELAY_SEC=0.25
LOG_LEVEL=INFO
